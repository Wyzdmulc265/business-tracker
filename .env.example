# Environment Configuration
# Set to 'development' for local development, 'production' for Render deployment
NODE_ENV=development

# Database Configuration
# For local development with SQLite:
DATABASE_URL=sqlite:./database.sqlite

# For production on Render (PostgreSQL will be auto-provisioned):
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Server Configuration
PORT=5000

# Security Configuration
# Generate a new secret key for production using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=your-secure-secret-key-here-change-in-production