<h1 class="page-header">
    <i class="fas fa-history"></i>
    Transaction History
</h1>

<div class="card filter-card">
    <div class="nav-tabs">
        <a href="/history<%= filterCategory || filterStart || filterEnd ? '?' + (filterCategory ? 'category=' + filterCategory : '') + (filterStart ? '&start_date=' + filterStart : '') + (filterEnd ? '&end_date=' + filterEnd : '') : '' %>" class="nav-tab <%= !filterType ? 'active' : '' %>">
            <i class="fas fa-list"></i>
            All
        </a>
        <a href="/history?type=sale<%= filterCategory ? '&category=' + filterCategory : '' %><%= filterStart ? '&start_date=' + filterStart : '' %><%= filterEnd ? '&end_date=' + filterEnd : '' %>" class="nav-tab <%= filterType === 'sale' ? 'active' : '' %>">
            <i class="fas fa-arrow-up"></i>
            Sales
        </a>
        <a href="/history?type=expense<%= filterCategory ? '&category=' + filterCategory : '' %><%= filterStart ? '&start_date=' + filterStart : '' %><%= filterEnd ? '&end_date=' + filterEnd : '' %>" class="nav-tab <%= filterType === 'expense' ? 'active' : '' %>">
            <i class="fas fa-arrow-down"></i>
            Expenses
        </a>
    </div>

    <form method="GET" action="/history" class="filter-form">
        <div class="filter-row">
            <div class="form-group" style="display: none;">
                <input type="hidden" name="type" value="<%= filterType || '' %>">
            </div>

            <div class="form-group">
                <label for="category">Category</label>
                <select id="category" name="category" class="form-control">
                    <option value="">All Categories</option>
                    <% categories.forEach(function(cat) { %>
                        <option value="<%= cat.id %>" <%= parseInt(filterCategory) === cat.id ? 'selected' : '' %>><%= cat.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="form-group">
                <label for="start_date">From Date</label>
                <input type="date" id="start_date" name="start_date" value="<%= filterStart %>" class="form-control">
            </div>

            <div class="form-group">
                <label for="end_date">To Date</label>
                <input type="date" id="end_date" name="end_date" value="<%= filterEnd %>" class="form-control">
            </div>

            <div class="filter-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-filter"></i> Filter
                </button>
                <a href="/history" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Clear
                </a>
            </div>
        </div>
    </form>
</div>

<div class="card">
    <% if (transactions && transactions.length > 0) { %>
        <div class="table-responsive">
            <table class="transactions-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% 
                    let totalSales = 0;
                    let totalExpenses = 0;
                    transactions.forEach(function(t) { 
                        if (t.type === 'sale') totalSales += t.amount;
                        else totalExpenses += t.amount;
                    %>
                        <tr>
                            <td><%= new Date(t.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                            <td>
                                <span class="type-badge <%= t.type === 'sale' ? 'type-sale' : 'type-expense' %>">
                                    <%= t.type === 'sale' ? 'Sale' : 'Expense' %>
                                </span>
                            </td>
                            <td><%= t.category ? t.category.name : '-' %></td>
                            <td><%= t.description || '-' %></td>
                            <td class="amount-cell <%= t.type === 'sale' ? 'amount-positive' : 'amount-negative' %>">
                                <%= t.type === 'sale' ? '+' : '-' %>$<%= t.amount.toFixed(2) %>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="/edit/<%= t.id %>" class="btn btn-sm btn-outline" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="POST" action="/delete/<%= t.id %>" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this transaction?');">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="btn btn-sm btn-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <div class="summary-section">
            <div class="summary-item">
                <span class="summary-label">Total Sales:</span>
                <span class="amount-positive">$<%= totalSales.toFixed(2) %></span>
            </div>
            <div class="summary-item">
                <span class="summary-label">Total Expenses:</span>
                <span class="amount-negative">$<%= totalExpenses.toFixed(2) %></span>
            </div>
        </div>
    <% } else { %>
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-receipt"></i>
            </div>
            <p>No transactions found.</p>
            <a href="/add" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add Transaction
            </a>
        </div>
    <% } %>
</div>