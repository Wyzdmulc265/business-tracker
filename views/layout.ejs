<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self'; connect-src 'self'; img-src 'self' data:;">
    <title><%- typeof title !== 'undefined' ? title : 'TrackWise' %></title>
    <link rel="stylesheet" href="/style.css">
    <link href="/font-awesome/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <i class="fas fa-chart-line"></i>
                <span>TrackWise</span>
            </div>
            <button class="sidebar-close" id="sidebarClose">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <nav class="sidebar-nav">
            <ul>
                <% if (userName) { %>
                    <li>
                        <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <% if (userRole !== 'super_admin') { %>
                    <li>
                        <a href="/add" class="<%= currentPath === '/add' ? 'active' : '' %>">
                            <i class="fas fa-plus-circle"></i>
                            <span>Add Transaction</span>
                        </a>
                    </li>
                    <% } %>
                    <li>
                        <a href="/history" class="<%= currentPath === '/history' ? 'active' : '' %>">
                            <i class="fas fa-history"></i>
                            <span>History</span>
                        </a>
                    </li>
                    <li>
                        <a href="/reports" class="<%= currentPath === '/reports' ? 'active' : '' %>">
                            <i class="fas fa-chart-bar"></i>
                            <span>Reports</span>
                        </a>
                    </li>
                    <% if ((userRole === 'business_admin' || userRole === 'super_admin')) { %>
                    <li>
                        <a href="/pending-approvals" class="<%= currentPath === '/pending-approvals' ? 'active' : '' %>">
                            <i class="fas fa-check-circle"></i>
                            <span>Approvals</span>
                        </a>
                    </li>
                    <% } %>
                    <% if ((userRole === 'business_admin' || userRole === 'super_admin')) { %>
                    <li>
                        <a href="/users" class="<%= currentPath === '/users' ? 'active' : '' %>">
                            <i class="fas fa-users"></i>
                            <span>Users</span>
                        </a>
                    </li>
                    <% } %>
                <% } %>
            </ul>
        </nav>

        <div class="sidebar-footer">
            <% if (userName) { %>
                <div class="user-profile">
                    <div class="user-avatar">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="user-info">
                        <div class="user-name"><%= typeof userName !== 'undefined' ? userName : '' %></div>
                        <div class="user-role"><%= typeof userRole !== 'undefined' ? userRole.replace('_', ' ').replace(/\b\w/g, l => l.toUpperCase()) : '' %></div>
                    </div>
                </div>
                <a href="/logout" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            <% } %>
        </div>
    </div>

    <div class="main-content" id="mainContent">
        <header class="top-header">
            <button class="sidebar-toggle" id="sidebarToggle">
                <i class="fas fa-bars"></i>
            </button>

            <div class="header-actions">
                <% if (userName) { %>
                    <% if (userRole !== 'super_admin') { %>
                    <a href="/profile" class="btn btn-outline">
                        <i class="fas fa-user-edit"></i>
                        Profile
                    </a>
                    <% } %>
                <% } else { %>
                    <a href="/login" class="btn btn-primary">
                        <i class="fas fa-sign-in-alt"></i>
                        Login
                    </a>
                <% } %>
            </div>
        </header>

        <main class="page-content">
            <% if (typeof messages !== 'undefined' && messages) { %>
                <% if (messages.error && messages.error.length > 0) { %>
                    <div class="flash-container">
                        <% messages.error.forEach(function(msg) { %>
                            <div class="alert alert-error">
                                <i class="fas fa-exclamation-circle"></i>
                                <%= msg %>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
                <% if (messages.success && messages.success.length > 0) { %>
                    <div class="flash-container">
                        <% messages.success.forEach(function(msg) { %>
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle"></i>
                                <%= msg %>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            <% } %>

            <%- body %>
        </main>

        <footer class="main-footer">
            <div class="footer-content">
                <div class="footer-left">
                    <p>&copy; 2026 TrackWise. All rights reserved.</p>
                </div>
                <div class="footer-right">
                    <p>Created by WizTech Solution</p>
                </div>
            </div>
        </footer>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script src="/main.js"></script>
</body>
</html>
