<div class="page-header">
     <i class="fas fa-tachometer-alt"></i>
     Dashboard Overview
 </div>

 <div class="dashboard-grid">
     <div class="card summary-card sales">
         <i class="fas fa-dollar-sign icon"></i>
         <h3>Today's Sales</h3>
         <div class="value">$<%= todaySales.toFixed(2) %></div>
     </div>

     <div class="card summary-card purchases">
         <i class="fas fa-shopping-cart icon"></i>
         <h3>Today's Purchases</h3>
         <div class="value">$<%= todayPurchases.toFixed(2) %></div>
     </div>

     <div class="card summary-card other-expenses">
         <i class="fas fa-file-invoice-dollar icon"></i>
         <h3>Today's Other Expenses</h3>
         <div class="value">$<%= todayOtherExpenses.toFixed(2) %></div>
     </div>

     <div class="card summary-card gross-profit">
         <i class="fas fa-chart-line icon"></i>
         <h3>Today's Gross Profit</h3>
         <div class="value">$<%= todayGrossProfit.toFixed(2) %></div>
     </div>

     <div class="card summary-card net-profit">
         <i class="fas fa-coins icon"></i>
         <h3>Today's Net Profit</h3>
         <div class="value">$<%= todayNetProfit.toFixed(2) %></div>
     </div>

     <div class="card summary-card sales">
         <i class="fas fa-calendar-alt icon"></i>
         <h3>This Month's Sales</h3>
         <div class="value">$<%= monthSales.toFixed(2) %></div>
     </div>

     <div class="card summary-card purchases">
         <i class="fas fa-shopping-cart icon"></i>
         <h3>This Month's Purchases</h3>
         <div class="value">$<%= monthPurchases.toFixed(2) %></div>
     </div>

     <div class="card summary-card other-expenses">
         <i class="fas fa-file-invoice-dollar icon"></i>
         <h3>This Month's Other Expenses</h3>
         <div class="value">$<%= monthOtherExpenses.toFixed(2) %></div>
     </div>

     <div class="card summary-card gross-profit">
         <i class="fas fa-chart-line icon"></i>
         <h3>This Month's Gross Profit</h3>
         <div class="value">$<%= monthGrossProfit.toFixed(2) %></div>
     </div>

     <div class="card summary-card net-profit">
         <i class="fas fa-coins icon"></i>
         <h3>This Month's Net Profit</h3>
         <div class="value">$<%= monthNetProfit.toFixed(2) %></div>
     </div>
 </div>

<div class="card">
    <h3 style="margin-bottom: 1.5rem; color: var(--gray-900); font-size: 1.25rem; font-weight: 600;">
        <i class="fas fa-bolt" style="color: var(--primary-color); margin-right: 0.5rem;"></i>
        Quick Actions
    </h3>
    <div class="d-flex" style="gap: 1rem; flex-wrap: wrap;">
        <% if (userRole !== 'super_admin') { %>
        <a href="/add" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Add Transaction
        </a>
        <% } %>
        <a href="/history" class="btn btn-outline">
            <i class="fas fa-history"></i>
            View History
        </a>
        <a href="/reports" class="btn btn-outline">
            <i class="fas fa-chart-bar"></i>
            Generate Report
        </a>
        <% if ((userRole === 'business_admin' || userRole === 'super_admin') || (userRole === 'super_admin')) { %>
        <a href="/pending-approvals" class="btn btn-warning">
            <i class="fas fa-check-circle"></i>
            Pending Approvals
        </a>
        <% } %>
    </div>
</div>

<% if (recentTransactions && recentTransactions.length > 0) { %>
<div class="card" style="margin-top: 1rem;">
    <h3 style="margin-bottom: 1rem;">Recent Transactions</h3>
    <div class="table-responsive">
        <table class="transactions-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                <% recentTransactions.forEach(function(t) { %>
                <tr>
                    <td><%= new Date(t.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                    <td>
                        <span class="type-badge <%= t.type === 'sale' ? 'type-sale' : 'type-expense' %>">
                            <%= t.type === 'sale' ? 'Sale' : 'Expense' %>
                        </span>
                    </td>
                    <td><%= t.category ? t.category.name : '-' %></td>
                    <td class="amount-cell <%= t.type === 'sale' ? 'amount-positive' : 'amount-negative' %>">
                        <%= t.type === 'sale' ? '+' : '-' %>$<%= t.amount.toFixed(2) %>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
<% } %>
