<h1 class="page-header">
     <i class="fas fa-chart-bar"></i>
     Reports & Analytics
 </h1>

 <div class="card">
     <div class="reports-grid">
         <div class="report-card">
             <h3>Total Sales</h3>
             <div class="value positive">$<%= totalSales.toFixed(2) %></div>
         </div>
         <div class="report-card">
             <h3>Total Purchases</h3>
             <div class="value negative">$<%= totalPurchases.toFixed(2) %></div>
         </div>
         <div class="report-card">
             <h3>Total Other Expenses</h3>
             <div class="value negative">$<%= totalOtherExpenses.toFixed(2) %></div>
         </div>
         <div class="report-card">
             <h3>Gross Profit</h3>
             <div class="value <%= totalGrossProfit >= 0 ? 'positive' : 'negative' %>">
                 $<%= totalGrossProfit.toFixed(2) %>
             </div>
         </div>
         <div class="report-card">
             <h3>Net Profit</h3>
             <div class="value <%= totalNetProfit >= 0 ? 'positive' : 'negative' %>">
                 $<%= totalNetProfit.toFixed(2) %>
             </div>
         </div>
     </div>
 </div>

<div class="nav-tabs">
    <button class="nav-tab active" data-tab="daily">
        <i class="fas fa-calendar-day"></i>
        Daily Trend
    </button>
    <button class="nav-tab" data-tab="monthly">
        <i class="fas fa-calendar-alt"></i>
        Monthly Summary
    </button>
</div>

<div id="daily-tab" class="nav-tab-content active">
     <div class="card chart-container">
         <h2>Last 7 Days Trend</h2>
         <div class="chart-bars">
             <% dailySummary.forEach(function(day) { %>
                 <div class="chart-bar">
                     <div class="bar-value">$<%= Math.round(day.netProfit) %></div>
                     <div class="bar daily-bar <%= day.netProfit >= 0 ? 'bar-positive' : 'bar-negative' %>" style="height: <%= day.bar_height %>px;"></div>
                     <div class="bar-label"><%= new Date(day.date).toLocaleDateString('en-US', { weekday: 'short' }) %></div>
                 </div>
             <% }); %>
         </div>
         <div class="daily-details">
             <% dailySummary.forEach(function(day) { %>
                 <div class="daily-detail">
                     <strong><%= new Date(day.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></strong><br>
                     Sales: $<%= Math.round(day.sales) %><br>
                     Purchases: $<%= Math.round(day.purchases) %><br>
                     Other Expenses: $<%= Math.round(day.otherExpenses) %><br>
                     Gross Profit: <span class="gross-profit <%= day.grossProfit >= 0 ? 'profit-positive' : 'profit-negative' %>">$<%= Math.round(day.grossProfit) %></span><br>
                     Net Profit: <span class="net-profit <%= day.netProfit >= 0 ? 'profit-positive' : 'profit-negative' %>">$<%= Math.round(day.netProfit) %></span>
                 </div>
             <% }); %>
         </div>
     </div>
 </div>

<div id="monthly-tab" class="nav-tab-content">
     <div class="card chart-container monthly-chart">
         <h2>Last 6 Months Summary</h2>
         <div class="chart-bars">
             <% monthlyTotals.forEach(function(month) { %>
                 <div class="chart-bar">
                     <div class="bar-value">$<%= Math.round(month.netProfit) %></div>
                     <div class="bar monthly-bar <%= month.netProfit >= 0 ? 'bar-positive' : 'bar-negative' %>" style="height: <%= month.bar_height %>px;"></div>
                     <div class="bar-label"><%= month.month.substring(0, 3) %></div>
                 </div>
             <% }); %>
         </div>
         <div class="monthly-details">
             <% monthlyTotals.forEach(function(month) { %>
                 <div class="monthly-detail">
                     <strong><%= month.month %></strong><br>
                     Sales: $<%= Math.round(month.sales) %><br>
                     Purchases: $<%= Math.round(month.purchases) %><br>
                     Other Expenses: $<%= Math.round(month.otherExpenses) %><br>
                     Gross Profit: <span class="gross-profit <%= month.grossProfit >= 0 ? 'profit-positive' : 'profit-negative' %>">$<%= Math.round(month.grossProfit) %></span><br>
                     Net Profit: <span class="net-profit <%= month.netProfit >= 0 ? 'profit-positive' : 'profit-negative' %>">$<%= Math.round(month.netProfit) %></span>
                 </div>
             <% }); %>
         </div>
     </div>
 </div>

<div class="card additional-stats">
    <a href="/history" class="btn btn-primary">
        <i class="fas fa-history"></i>
        View Full Transaction History
    </a>
</div>