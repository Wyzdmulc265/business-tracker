<div class="form-container">
    <h1 class="page-header">Edit Transaction</h1>

    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <div class="alert alert-error">
            <% errors.forEach(function(err) { %>
                <div><%= err %></div>
            <% }); %>
        </div>
    <% } %>

    <div class="card">
        <form method="POST" action="/edit/<%= transaction.id %>">
            <div class="form-group">
                <label>Transaction Type *</label>
                <div class="form-radio-group">
                    <label class="form-radio-label">
                        <input type="radio" name="type" value="sale" <%= transaction.type === 'sale' ? 'checked' : '' %>>
                        💰 Sale
                    </label>
                    <label class="form-radio-label">
                        <input type="radio" name="type" value="expense" <%= transaction.type === 'expense' ? 'checked' : '' %>>
                        💸 Expense
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label for="amount">Amount ($) *</label>
                <input type="number" step="0.01" min="0" id="amount" name="amount" required value="<%= transaction.amount %>" placeholder="0.00">
            </div>

            <div class="form-group">
                <label for="category_id">Category *</label>
                <select id="category_id" name="category_id" required>
                    <option value="">Select a category</option>
                    <% categories.forEach(function(category) { %>
                        <option value="<%= category.id %>" <%= category.id === transaction.category_id ? 'selected' : '' %>>
                            <%= category.name %>
                        </option>
                    <% }); %>
                </select>
            </div>

            <div class="inventory-fields" id="inventoryFields" style="display: <%= transaction.type === 'sale' ? 'block' : 'none' %>;">
                <div class="form-group">
                    <label for="inventory_item_id">Inventory Item</label>
                    <select id="inventory_item_id" name="inventory_item_id" class="form-control">
                        <option value="">Select inventory item (optional)</option>
                        <% if (typeof inventoryItems !== 'undefined' && inventoryItems) { %>
                            <% inventoryItems.forEach(function(item) { %>
                                <option value="<%= item.id %>" <%= transaction.inventory_item_id == item.id ? 'selected' : '' %>>
                                    <%= item.name %> (<%= item.sku %>)
                                </option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="quantity">Quantity Sold</label>
                    <input type="number" id="quantity" name="quantity" min="0" step="1" value="<%= transaction.quantity || '' %>" class="form-control">
                </div>

                <div class="form-group">
                    <label for="unit_cost">Unit Cost</label>
                    <input type="number" id="unit_cost" name="unit_cost" min="0" step="0.01" value="<%= transaction.unit_cost || '' %>" class="form-control">
                </div>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3" placeholder="Optional note about this transaction"><%= transaction.description || '' %></textarea>
            </div>

            <div class="form-group">
                <label for="date">Date</label>
                <input type="date" id="date" name="date" value="<%= new Date(transaction.date).toISOString().split('T')[0] %>">
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-success">Update Transaction</button>
                <a href="/history" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<script src="/add_transaction.js"></script>
