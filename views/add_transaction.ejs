<div class="form-container">
    <h1 class="page-header">Add Transaction</h1>

    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <div class="alert alert-error">
            <% errors.forEach(function(err) { %>
                <div><%= err %></div>
            <% }); %>
        </div>
    <% } %>

    <div class="card">
        <form method="POST" action="/add" class="transaction-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
                <label>Transaction Type *</label>
                <div class="type-toggle">
                    <label class="type-option active">
                        <input type="radio" name="type" value="sale" checked>
                        <i class="fas fa-arrow-up"></i>
                        <span>Sale</span>
                    </label>
                    <label class="type-option">
                        <input type="radio" name="type" value="expense">
                        <i class="fas fa-arrow-down"></i>
                        <span>Expense</span>
                    </label>
                </div>
            </div>

            <div class="form-group">
                <label for="amount">Amount *</label>
                <div class="input-group">
                    <span class="input-prefix">$</span>
                    <input type="number" step="0.01" min="0" id="amount" name="amount" required placeholder="0.00" class="form-control">
                </div>
            </div>

            <div class="form-group">
                <label for="category_id">Category *</label>
                <select id="category_id" name="category_id" required class="form-control">
                    <option value="">Select a category</option>
                    <% categories.forEach(function(category) { %>
                        <option value="<%= category.id %>" data-category-type="<%= category.type %>"><%= category.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="inventory-fields" id="inventoryFields" style="display: none;">
                <div class="form-group">
                    <label for="inventory_item_id">Inventory Item</label>
                    <select id="inventory_item_id" name="inventory_item_id" class="form-control">
                        <option value="">Select an inventory item</option>
                        <% if (typeof inventoryItems !== 'undefined' && inventoryItems) { %>
                            <% inventoryItems.forEach(function(item) { %>
                                <option value="<%= item.id %>"><%= item.name %> (<%= item.sku %>)</option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="quantity">Quantity</label>
                    <input type="number" id="quantity" name="quantity" min="0" step="1" class="form-control" placeholder="0">
                </div>

                <div class="form-group">
                    <label for="unit_cost">Unit Cost</label>
                    <div class="input-group">
                        <span class="input-prefix">$</span>
                        <input type="number" id="unit_cost" name="unit_cost" min="0" step="0.01" class="form-control" placeholder="0.00">
                    </div>
                </div>

                <p class="form-helper">These fields are used for sales and inventory valuation.</p>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3" placeholder="Optional note about this transaction" class="form-control"></textarea>
            </div>

            <div class="form-group">
                <label for="date">Date</label>
                <input type="date" id="date" name="date" value="<%= today %>" class="form-control">
                <small class="form-text">Leave empty for today's date</small>
            </div>

            <button type="submit" class="btn btn-success btn-block">
                <i class="fas fa-plus-circle"></i>
                Add Transaction
            </button>
        </form>
    </div>
</div>

<script src="/add_transaction.js"></script>
